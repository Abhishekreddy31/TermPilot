{
  "name": "@abhishekreddy31/term-pilot",
  "version": "1.0.6",
  "description": "Control your laptop's terminal from your phone. Voice commands, multi-session tabs, tmux mirroring, remote access.",
  "license": "MIT",
  "author": "Abhishek Reddy <abhisheksingireddy31@gmail.com> (https://github.com/Abhishekreddy31)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Abhishekreddy31/TermPilot.git"
  },
  "homepage": "https://github.com/Abhishekreddy31/TermPilot#readme",
  "bugs": {
    "url": "https://github.com/Abhishekreddy31/TermPilot/issues"
  },
  "keywords": [
    "terminal",
    "remote-terminal",
    "pwa",
    "voice-control",
    "tmux",
    "xterm",
    "websocket",
    "mobile",
    "developer-tools",
    "node-pty",
    "cloudflare-tunnel",
    "cli"
  ],
  "bin": {
    "term-pilot": "dist/cli.js"
  },
  "type": "module",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:server": "pnpm --filter @termpilot/server dev",
    "dev:client": "pnpm --filter @termpilot/client dev",
    "build": "pnpm --filter @termpilot/shared build && pnpm --filter @termpilot/client build && pnpm --filter @termpilot/server build",
    "build:publish": "node scripts/build-publish.js",
    "test": "pnpm --filter @termpilot/shared --filter @termpilot/server --filter @termpilot/client run test",
    "start": "pnpm run build && node packages/server/dist/cli/cli.js",
    "test:watch": "pnpm -r --parallel run test:watch",
    "test:coverage": "pnpm -r run test:coverage",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean && rm -rf dist",
    "e2e": "pnpm --filter @termpilot/e2e test",
    "audit": "pnpm audit --prod",
    "postinstall": "node -e \"const{chmodSync:c,readdirSync:r}=require('fs'),{join:j}=require('path');try{const d=j(require.resolve('node-pty'),'..','prebuilds');r(d).forEach(p=>{try{c(j(d,p,'spawn-helper'),'755')}catch{}})}catch{}\"",
    "prepublishOnly": "node scripts/build-publish.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "dependencies": {
    "node-pty": "^1.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "node-pty"
    ]
  }
}
